@page "/moderation/panel"
@rendermode InteractiveServer
@using PLGarageFrontend.Services
@using System.Text.Json
@inject ModerationService Moderation
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedLocalStorage ProtectedLocalStorage
@inject IJSRuntime JSRuntime

<PageTitle>Moderation Panel</PageTitle>

<link href="css/mod.css" rel="stylesheet" />

<h1>Moderation Panel</h1>

@if (!Moderation.IsLoggedIn)
{
    <p>You are not logged in, and you do not have permission to access this page.</p>
    <p>If you are a moderator of this instance, <a href="/moderation/login">Log in here</a>.</p>
}
else
{
    <div class="controls-row" style="justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <div>
            <strong>Authenticated as @modUsername</strong>
        </div>
        <div>
            <a href="#" @onclick="DoLogout">Log out</a>
        </div>
    </div>

    <div class="mod-panel-layout">
        <div class="mod-tabs-vertical">
            <div class="mod-tab-item @(activeTab == "server" ? "active" : "")" @onclick='() => activeTab = "server"'>
                Server Management
            </div>
            <div class="mod-tab-item @(activeTab == "creations" ? "active" : "")" @onclick='() => activeTab = "creations"'>
                Creation Management
            </div>
            <div class="mod-tab-item @(activeTab == "grief" ? "active" : "")" @onclick='() => activeTab = "grief"'>
                Good Grief!
            </div>
            <div class="mod-tab-item @(activeTab == "users" ? "active" : "")" @onclick='() => activeTab = "users"'>
                Users Management
            </div>
        </div>

        <div class="mod-tab-content">
            <div class="mod-tab-pane @(activeTab == "server" ? "active" : "")">
                <section class="mod-section">
                    <h2>Announcements</h2>
                    
                    <div class="mod-create-announcement">
                        <h3>Create new announcement</h3>
                        <div class="mod-form">
                            <div class="mod-field">
                                <label>Platform</label>
                                <select @bind="newPlatform">
                                    <option value="PS3">ModNation Racers (PS3)</option>
                                    <option value="PSV">ModNation Racers: Road Trip (PSV)</option>
                                    <option value="PSP">ModNation Racers (PSP)</option>
                                    <option value="WEB">WEB</option>
                                </select>
                            </div>
                            <div class="mod-field">
                                <label>Language Code</label>
                                <input type="text" @bind="newLanguageCode" placeholder="en-US" />
                            </div>
                            <div class="mod-field">
                                <label>Subject</label>
                                <input type="text" @bind="newSubject" placeholder="Important Update" />
                            </div>
                            <div class="mod-field">
                                <label>Text</label>
                                <textarea @bind="newText" rows="4" placeholder="Announcement message..."></textarea>
                            </div>
                            <button @onclick="CreateAnnouncement" disabled="@creating">
                                @(creating ? "Creating..." : "Create Announcement")
                            </button>
                            @if (!string.IsNullOrEmpty(createMessage))
                            {
                                <p class="mod-message">@createMessage</p>
                            }
                        </div>
                    </div>

                    <div class="mod-announcements-list">
                        <h3>Existing Announcements</h3>
                        @if (loadingAnnouncements)
                        {
                            <p>Loading...</p>
                        }
                        else if (announcements.Count == 0)
                        {
                            <p>No announcements found.</p>
                        }
                        else
                        {
                            <table class="mod-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Platform</th>
                                        <th>Lang</th>
                                        <th>Subject</th>
                                        <th>Text</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in announcements)
                                    {
                                        <tr>
                                            <td>@a.Id</td>
                                            <td>@a.Platform</td>
                                            <td>@a.LanguageCode</td>
                                            <td>@a.Subject</td>
                                            <td class="mod-text-preview">@a.Text</td>
                                            <td>@a.CreatedAt</td>
                                            <td>
                                                <button @onclick="() => DeleteAnnouncement(a.Id)"
                                                        disabled="@deleting"
                                                        class="mod-delete-btn">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            
                            <div class="mod-pagination">
                                <button @onclick="PrevAnnouncementsPage" disabled="@(announcementsPage <= 1 || loadingAnnouncements)">Previous</button>
                                <span>Page @announcementsPage of @announcementsTotalPages</span>
                                <button @onclick="NextAnnouncementsPage" disabled="@(announcementsPage >= announcementsTotalPages || loadingAnnouncements)">Next</button>
                            </div>
                        }
                    </div>
                </section>
            </div>

            <div class="mod-tab-pane @(activeTab == "creations" ? "active" : "")">
                <section class="mod-section">
                    <div class="p-3">
                        <h3>Ban creation (BROKEN I THINK?)</h3>
            
                        <p>Enter a Creation ID to ban it.</p>

                        <div style="margin-bottom: 15px;">
                            <label>Creation ID:</label>
                            <input type="number" @bind="targetCreationId" style="display: block; width: 100%; padding: 5px; margin-top: 5px;" />
                        </div>

                        <button class="mod-btn-danger" @onclick="() => BanCreation(targetCreationId)">
                            Ban it!
                        </button>
                    </div>
                </section>
            </div>

            <div class="mod-tab-pane @(activeTab == "users" ? "active" : "")">
                <section class="mod-section">
                    <h2>User Management</h2>
        
                    @if (loadingUsers)
                    {
                        <p>Loading users...</p>
                    }
                    else if (userList.Count == 0)
                    {
                        <p>No users found.</p>
                    }
                    else
                    {
                        <table class="mod-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Banned?</th>
                                    <th>PSN Linked</th>
                                    <th>RPCN Linked</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in userList)
                                {
                                    <tr>
                                        <td>@user.Id</td>
                                        <td>@user.Username</td>
                                        <td>
                                            <span class="badge @(user.IsBanned ? "bg-danger" : "bg-success")">
                                                @(user.IsBanned ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>@(user.IsPsnLinked ? "YES" : "NO")</td>
                                        <td>@(user.IsRpcnLinked ? "YES" : "NO")</td>
                                        <td>
                                            <span class="badge @(user.IsBanned ? "bg-danger" : "bg-success")">
                                                @(user.IsBanned ? "Banned" : "Active")
                                            </span>
                                        </td>
                                        <td>
                                            @if (user.IsBanned)
                                            {
                                                <button class="mod-btn-small btn-unban" @onclick="() => ToggleBan(user)">
                                                    Unban
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="mod-btn-small btn-ban" @onclick="() => ToggleBan(user)">
                                                    Ban
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="mod-pagination">
                            <button @onclick="PrevUsersPage" disabled="@(usersPage <= 1 || loadingUsers)">Previous</button>
                            <span>Page @usersPage</span>
                            <button @onclick="NextUsersPage" disabled="@(userList.Count < perPage || loadingUsers)">Next</button>
                        </div>
                    }
                </section>
            </div>
        </div>
    </div>
}

@code {
    private string activeTab = "server";
    private string modUsername = "";
    private bool debug_storage_token_present = false;
    private int debug_storage_token_length = 0;
    private bool debug_storage_username_present = false;

    private class Announcement
    {
        public int Id { get; set; }
        public string Platform { get; set; } = "";
        public string LanguageCode { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Text { get; set; } = "";
        public string CreatedAt { get; set; } = "";
    }

    private List<Announcement> announcements = new();
    private bool loadingAnnouncements = false;
    private int announcementsPage = 1;
    private int announcementsTotalPages = 1;
    private const int perPage = 20;

    private string newPlatform = "PS3";
    private string newLanguageCode = "en-US";
    private string newSubject = "";
    private string newText = "";
    private bool creating = false;
    private string createMessage = "";
    private bool deleting = false;

    private int teamPickCreationId = 0;
    private bool settingTeamPick = false;
    private string teamPickMessage = "";

    private List<UserEntry> userList = new();
    private bool loadingUsers = false;
    private int usersPage = 1;

    private int targetCreationId;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await Moderation.InitializeAsync();
            modUsername = Moderation.Username;

            try
            {

                var u = await ProtectedLocalStorage.GetAsync<string>("mod_username");
                debug_storage_username_present = u.Success && !string.IsNullOrEmpty(u.Value);
            }
            catch { }

            if (!Moderation.IsLoggedIn)
            {
                Nav.NavigateTo("/moderation/login");
                return;
            }
        }
        catch { }

        await LoadAnnouncements();
        await LoadUsers();
        StateHasChanged();
    }

    private async Task LoadAnnouncements()
    {
        loadingAnnouncements = true;
        try
        {
            var result = await Moderation.GetAnnouncementsAsync(announcementsPage, perPage);
            if (result != null)
            {
                var doc = JsonDocument.Parse(result);
                var root = doc.RootElement;

                if (root.TryGetProperty("Total", out var totalProp))
                {
                    var total = totalProp.GetInt32();
                    announcementsTotalPages = (int)Math.Ceiling(total / (double)perPage);
                }

                if (root.TryGetProperty("Page", out var pageProp) && pageProp.ValueKind == JsonValueKind.Array)
                {
                    announcements = pageProp.EnumerateArray().Select(a => new Announcement
                    {
                        Id = a.TryGetProperty("Id", out var id) ? id.GetInt32() : 0,
                        Platform = a.TryGetProperty("Platform", out var plat) ? PlatformIntToString(plat.GetInt32()) : "",
                        LanguageCode = a.TryGetProperty("LanguageCode", out var lang) ? lang.GetString() ?? "" : "",
                        Subject = a.TryGetProperty("Subject", out var subj) ? subj.GetString() ?? "" : "",
                        Text = a.TryGetProperty("Text", out var txt) ? txt.GetString() ?? "" : "",
                        CreatedAt = a.TryGetProperty("CreatedAt", out var created) ? created.GetString() ?? "" : "",
                    }).ToList();
                }
                else
                {
                    announcements = new();
                }
            }
        }
        catch
        {
            announcements = new();
        }
        finally
        {
            loadingAnnouncements = false;
        }
    }

    private async Task CreateAnnouncement()
    {
        if (string.IsNullOrWhiteSpace(newSubject) || string.IsNullOrWhiteSpace(newText))
        {
            createMessage = "Subject and text are required.";
            return;
        }

        creating = true;
        createMessage = "";

        try
        {
            var result = await Moderation.CreateAnnouncementAsync(newLanguageCode, newSubject, newText, newPlatform);
            if (result == "ok")
            {
                createMessage = "Announcement created successfully!";
                newSubject = "";
                newText = "";
                newLanguageCode = "en-US";
                await LoadAnnouncements();
            }
            else
            {
                createMessage = $"Failed to create announcement: {result}";
            }
        }
        catch (Exception ex)
        {
            createMessage = $"Error: {ex.Message}";
        }
        finally
        {
            creating = false;
        }
    }

    private async Task DeleteAnnouncement(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this announcement?"))
            return;

        deleting = true;
        try
        {
            var result = await Moderation.DeleteAnnouncementAsync(id);
            if (result == "ok")
            {
                await LoadAnnouncements();
            }
        }
        catch { }
        finally
        {
            deleting = false;
        }
    }

    private async Task SetTeamPick()
    {
        if (teamPickCreationId <= 0)
        {
            teamPickMessage = "Please enter a valid creation ID.";
            return;
        }

        settingTeamPick = true;
        teamPickMessage = "";

        try
        {
            var result = await Moderation.SetModerationStatusAsync(teamPickCreationId, "TEAM_PICK");
            if (result == "ok")
            {
                teamPickMessage = $"Creation {teamPickCreationId} is now a Team Pick!";
                teamPickCreationId = 0;
            }
            else if (result == null)
            {
                teamPickMessage = "Creation not found or you don't have permission.";
            }
            else
            {
                teamPickMessage = $"Failed: {result}";
            }
        }
        catch (Exception ex)
        {
            teamPickMessage = $"Error: {ex.Message}";
        }
        finally
        {
            settingTeamPick = false;
        }
    }

    private async Task PrevAnnouncementsPage()
    {
        if (announcementsPage > 1)
        {
            announcementsPage--;
            await LoadAnnouncements();
        }
    }

    private async Task NextAnnouncementsPage()
    {
        if (announcementsPage < announcementsTotalPages)
        {
            announcementsPage++;
            await LoadAnnouncements();
        }
    }

    private void DoLogout()
    {
        Moderation.Logout();
        Nav.NavigateTo("/moderation/login");
    }

    private static string PlatformIntToString(int platformInt)
    {
        return platformInt switch
        {
            1 => "PSP",
            2 => "PS3",
            3 => "WEB",
            4 => "PSV",
            _ => platformInt.ToString()
        };
    }

    private class GriefReport
    {
        public int Id { get; set; }
        public int ReporterId { get; set; }
        public string Reason { get; set; } = "";
        public string Description { get; set; } = "";
        public string ImageUrl { get; set; } = "";
    }

    private class UserEntry
    {
        public int Id { get; set; }
        public string Username { get; set; } = "";
        public bool IsBanned { get; set; }
        public bool IsPsnLinked { get; set; }
        public bool IsRpcnLinked { get; set; }
    }

    private async Task LoadUsers()
    {
        loadingUsers = true;
        try
        {
            var result = await Moderation.GetUsersAsync(usersPage, perPage);
            if (result != null)
            {
                var doc = JsonDocument.Parse(result);
                var root = doc.RootElement;

                if (root.TryGetProperty("Page", out var pageProp) && pageProp.ValueKind == JsonValueKind.Array)
                {
                    userList = pageProp.EnumerateArray().Select(u => new UserEntry
                    {
                        Id = u.TryGetProperty("ID", out var id) ? id.GetInt32() : 0,
                        Username = u.TryGetProperty("Username", out var name) ? name.GetString() ?? "Unknown" : "Unknown",
                        IsBanned = u.TryGetProperty("IsBanned", out var b) && b.GetBoolean(),
                        IsPsnLinked = u.TryGetProperty("IsPSNLinked", out var p) && p.GetBoolean(),
                        IsRpcnLinked = u.TryGetProperty("IsRPCNLinked", out var r) && r.GetBoolean()
                    }).ToList();
                    Console.WriteLine($"DEBUG USER JSON: {result}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
        finally
        {
            loadingUsers = false;
        }
    }

    private async Task ToggleBan(UserEntry user)
    {
        bool newBanStatus = !user.IsBanned;
        string actionVerb = newBanStatus ? "ban" : "unban";

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Are you sure you want to {actionVerb} {user.Username} (ID: {user.Id})?");

        if (!confirmed) return;

        var result = await Moderation.SetBanAsync(user.Id, newBanStatus);

        if (result == "ok")
        {
            user.IsBanned = newBanStatus;
            StateHasChanged();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Server returned an error: {result}");
        }
    }

    private async Task PrevUsersPage() { if (usersPage > 1) { usersPage--; await LoadUsers(); } }
    private async Task NextUsersPage() { usersPage++; await LoadUsers(); }

    private async Task BanCreation(int id)
    {
        var result = await Moderation.SetModerationStatusAsync(id, "3");
        
        if (result != null)
        {
            Console.WriteLine($"[MOD] Creation {id} has been banned. Server said: {result}");
        }
        else
        {
            Console.WriteLine($"[ERR] Failed to ban creation {id}. Check permissions!");
        }

        var result2 = await Moderation.SetModerationStatusAsync(id, "2");
        
        if (result2 != null)
        {
            Console.WriteLine($"[MOD] Creation {id} has been banned. Server said: {result2}");
        }
        else
        {
            Console.WriteLine($"[ERR] Failed to ban creation {id}. Check permissions!");
        }
    }

}