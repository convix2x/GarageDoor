@page "/tracks"
@rendermode InteractiveServer
@using PLGarageFrontend.Models
@using PLGarageFrontend.Services
@inject PLGarageService PLGarage

<PageTitle>Tracks – @instanceName</PageTitle>

<h1>Tracks</h1>

<div>
    <button @onclick="() => SetGame(false)" disabled="@(!isMnr)">LBP Karting</button>
    <button @onclick="() => SetGame(true)" disabled="@(isMnr)">ModNation Racers</button>
</div>

<div>
    <input type="search"
           placeholder="Search tracks..."
           @bind="keyword"
           @bind:event="oninput"
           @onkeydown="OnSearchKeyDown" />

    <select @bind="sortColumn" @bind:after="ReloadAsync">
        <option value="created_at">Newest</option>
        <option value="hearts">Most Hearted</option>
        <option value="downloads">Most Downloaded</option>
        <option value="races_started">Most Played</option>
        <option value="rating_up">Highest Rated</option>
        <option value="views">Most Viewed</option>
    </select>
</div>

@if (loading)
{
    <p>Loading...</p>
}
else if (result?.Tracks is { Count: 0 })
{
    <p>No tracks found.</p>
}
else if (result is not null)
{
    <p>Showing @result.Tracks.Count of @result.Total tracks — Page @result.Page / @result.TotalPages</p>

    <div style="display:flex; flex-direction:column; gap:0.5rem;">
        @foreach (var track in result.Tracks)
        {
            <div style="border:1px solid black; padding:0.5rem; display:flex; gap:0.75rem; align-items:flex-start;">
                <div style="width:128px; height:128px; background:#ccc; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:0.7rem; color:#555;">
                    <img src="@($"{PLGarage.BaseUrl}/player_creations/{track.Id}/preview_image_128x128.png")"
                         alt="@track.Name"
                         width="128" height="128"
                         style="display:block;"
                         onerror="this.parentElement.innerHTML='No preview'" />
                </div>
                <div>
                    <div><b>@track.Name</b> by @track.Username</div>
                    @if (!string.IsNullOrWhiteSpace(track.Description))
                    {
                        <div>@track.Description</div>
                    }
                    <div>♥ @track.Hearts | ⬇ @track.Downloads | 🏁 @track.RacesStarted | 👁 @track.Views</div>
                    <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:4px;">
                        @if (track.NumLaps > 0)
                        {
                            <span style="border:1px solid #999; padding:1px 6px; font-size:0.75rem;">@track.NumLaps laps</span>
                        }
                        @if (!string.IsNullOrEmpty(track.RaceType))
                        {
                            <span style="border:1px solid #999; padding:1px 6px; font-size:0.75rem;">@track.RaceType</span>
                        }
                        @if (!string.IsNullOrEmpty(track.Difficulty))
                        {
                            <span style="border:1px solid #999; padding:1px 6px; font-size:0.75rem;">@track.Difficulty</span>
                        }
                        @if (track.IsTeamPick)
                        {
                            <span style="border:1px solid #999; padding:1px 6px; font-size:0.75rem;">⭐ Team Pick</span>
                        }
                        @foreach (var tag in track.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span style="border:1px solid #999; padding:1px 6px; font-size:0.75rem;">@tag</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div>
        <button disabled="@(result.Page <= 1)" @onclick="PrevPage">← Prev</button>
        <span>Page @result.Page of @result.TotalPages</span>
        <button disabled="@(result.Page >= result.TotalPages)" @onclick="NextPage">Next →</button>
    </div>
}

@code {
    private CreationsPage? result;
    private bool loading = true;
    private int page = 1;
    private string instanceName = "PL Garage";
    private string sortColumn = "created_at";
    private string keyword = "";
    private bool isMnr = false;

    protected override async Task OnInitializedAsync()
    {
        instanceName = await PLGarage.GetInstanceNameAsync();
        await ReloadAsync();
    }


    private async Task SetGame(bool mnr)
    {
        isMnr = mnr;
        page = 1;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        result = await PLGarage.GetTracksAsync(page, sortColumn: sortColumn, keyword: keyword, isMnr: isMnr);
        loading = false;
    }

    private async Task PrevPage()
    {
        if (page > 1) { page--; await ReloadAsync(); }
    }

    private async Task NextPage()
    {
        if (result is not null && page < result.TotalPages) { page++; await ReloadAsync(); }
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { page = 1; await ReloadAsync(); }
    }

}