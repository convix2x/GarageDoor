@page "/moderation/login"
@rendermode InteractiveServer
@using PLGarageFrontend.Services
@inject ModerationService Moderation
@inject NavigationManager Nav

<PageTitle>Moderation Login</PageTitle>

<link href="css/mod.css" rel="stylesheet" />

<h1>Moderation Login</h1>

@if (result == LoginResult.Success)
{
    <p class="mod-login-result mod-success">success</p>
    <p style="color: #999; font-size: 0.85rem;">Redirecting to panel... (IsLoggedIn: @Moderation.IsLoggedIn)</p>
    @if (isInsecure)
    {
        <p class="mod-login-warning">
            Warning: You logged in with default credentials (<code>admin</code> / <code>admin</code>).
            This server is insecure - please change the credentials in the backend configuration before using it in production!
        </p>
    }
}
else if (result == LoginResult.Fail)
{
    <p class="mod-login-result mod-fail">fail</p>
}

@if (result != LoginResult.Success)
{
    <div class="mod-login-form">
        <div class="mod-login-field">
            <label>Username</label>
            <input type="text" @bind="username" @bind:event="oninput" disabled="@loading" />
        </div>
        <div class="mod-login-field">
            <label>Password</label>
            <input type="password" @bind="password" @bind:event="oninput" disabled="@loading" />
        </div>
        <button @onclick="DoLogin" disabled="@loading">
            @(loading ? "Logging in..." : "Login")
        </button>
        @if (result == LoginResult.Error)
        {
            <p class="mod-login-error">Could not reach the server. Check the backend is running.</p>
        }
    </div>
}

@code {
    private string username = "";
    private string password = "";
    private bool loading = false;
    private bool isInsecure = false;

    private enum LoginResult { None, Success, Fail, Error }
    private LoginResult result = LoginResult.None;

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
            return;

        loading = true;
        result = LoginResult.None;

        try
        {
            var ok = await Moderation.LoginAsync(username, password);

            if (ok)
            {
                result = LoginResult.Success;
                isInsecure = username == "admin" && password == "admin";

                StateHasChanged();
                Nav.NavigateTo("/moderation/panel");
            }
            else
            {
                result = LoginResult.Fail;
            }
        }
        catch
        {
            result = LoginResult.Error;
        }
        finally
        {
            loading = false;
        }
    }
}