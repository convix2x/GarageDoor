@page "/players/{Id:int}"
@rendermode InteractiveServer
@using PLGarageFrontend.Models
@using PLGarageFrontend.Services
@using System.Formats.Asn1
@inject PLGarageService PLGarage
@inject IJSRuntime JS

<HeadContent>
    <link rel="stylesheet" href="css/profile.css" />
</HeadContent>

<PageTitle>@(profile?.Username ?? "Player") – @instanceName</PageTitle>

@if (loading)
{
    <p>Loading...</p>
}
else if (profile == null)
{
    <h1>Player not found</h1>
}
else
{

    <button @onclick="GoBack">← Back</button>
    <div class="profile-header">
        <img class="profile-avatar" src="@($"{PLGarage.BaseUrl}/player_avatars/{Id}/primary.png")" width="80" height="80"
             onerror="this.style.display='none'" />
        <div class="profile-header-info">

                <h1>@profile.Username</h1>

            
            @if (!string.IsNullOrWhiteSpace(profile.Quote))
            {

                    <p class="profile-quote">"@profile.Quote"</p>

            }

            <div class="profile-meta">

                    <span>@profile.Presence</span>
                    <span>Member since: @FormatDate(profile.CreatedAt)</span>
                    <span>Skill level: @profile.SkillLevel</span>
                    <div style="display:flex;"><img class="profile-sack"
                                src="@($"{PLGarage.BaseUrl}/player_avatars/{Id}/smiley.png")" width="80" height="80"
                                onerror="this.style.display='none'" />
                        <span class="PHearts">♥@profile.Hearts</span>
                    </div>


            </div>
        </div>
    </div>
    <div class="controls-row">
        <div class="button-group">
            <button @onclick='async () => activeTab = "Comments"' disabled="@(activeTab == "Comments")">Comments</button>
            <button @onclick='async () => { activeTab = "CLBPK"; Plt = "PS3";  await ReloadLBPK();}' disabled="@(activeTab == "CLBPK")">Creations (LBPK)</button>
            <button @onclick='async () => { activeTab = "CMNR"; Plt = "PS3"; await ReLoadMNRS(); }' disabled="@(activeTab == "CMNR")">Creations (MNR)</button>
            <button @onclick='async () => { activeTab = "CMRT"; Plt = "PSV"; await ReLoadMNRS(); }' disabled="@(activeTab == "CMRT")">Creations (MNR:RT)</button>
            <button @onclick='async () => activeTab = "Stats"' disabled="@(activeTab == "Stats")">Stats</button>
        </div>
    </div>
    @switch (activeTab)
    {
        case "Comments":
            @if (commentsLoading)
            {
                <h2>Profile Comments</h2>
                <p>Loading comments...</p>
            }
            else if (comments == null || comments.Comments.Count == 0)
            {
                <h2>Profile Comments</h2>
                <p>No comments yet.</p>
            }
            else
            {
                <h2>Profile Comments (@(comments.Comments.Count))</h2>
                <div class="comments-section">
                    @foreach (var comment in comments.Comments)
                    {
                        <div class="comment-card">
                            <div class="comment-author">
                                <div class="comment-author-info">
                                    <div style="display: flex; gap: 0.2rem;">
                                        <img class="comment-avatar"
                                             src="@($"{PLGarage.BaseUrl}/player_avatars/{comment.AuthorId}/primary.png")" width="80"
                                             height="80" onerror="this.style.display='none'" />
                                        <div style="display: block;">
                                            <a href="/players/@comment.PlayerId"><strong>@comment.Username</strong></a> <br/>
                                            <span class="comment-date">@FormatDate(comment.CreatedAt)</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="comment-body">@comment.Body</div>
                            <div class="comment-stats">
                                Yays @comment.RatingUp | Boos @comment.RatingDown
                            </div>
                        </div>
                    }
                </div>
                <div class="leaderboard-pagination">
                    <button disabled="@(comments.Page <= 1)" @onclick="CommentsPrevPage">← Prev</button>
                    <span>Page @comments.Page of @comments.TotalPages (@comments.Total total)</span>
                    <button disabled="@(comments.Page >= comments.TotalPages)" @onclick="CommentsNextPage">Next →</button>
                </div>
            }
            break;
        case "CLBPK":
            <h2>Tracks – LBP Karting</h2> <br />
            @if (tracksLoading)
            {
                <p>Loading...</p>
            }
            else if (lbpkTracks == null || lbpkTracks.Tracks.Count == 0)
            {
                <button @onclick='async () => { await ReloadLBPK(); }'>Reload</button> <br>
                <p>No LBPK tracks published.</p>
            }
            else
            {
                <button @onclick='async () => { await ReloadLBPK(); }' ">Reload</button> <br>
                <div class="track-list">
                    @foreach (var track in lbpkTracks.Tracks)
                    {
                        <div class="track-card">
                            <div class="track-preview">
                                <a href="/tracks/@track.Id">
                                    <img src="@($"{PLGarage.BaseUrl}/player_creations/{track.Id}/preview_image.png")" alt="@track.Name"
                                         onerror="this.parentElement.innerHTML=''" />
                                </a>
                            </div>
                            <div class="track-info">
                                <div class="track-name"><a href="/tracks/@track.Id">@track.Name</a></div>
                                @if (!string.IsNullOrWhiteSpace(track.Description))
                                {
                                    <div class="track-description">@track.Description</div>
                                }
                                <div class="track-stats">♥ @track.Hearts | ⬇ @track.Downloads | 🏁 @track.RacesStarted | 👁 @track.Views
                                </div>
                                <div class="tag-container">
                                    @if (track.IsTeamPick)
                                    {
                                        <span class="tag-badge tag-teampick">⭐ Team Pick</span>
                                    }
                                    @foreach (var tag in track.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries |
                                                                                                                                                        StringSplitOptions.TrimEntries))
                                    {
                                        <span class="tag-badge">@tag</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            break;
        case "CMNR":
            <h2>@(CreationType)S – ModNation Racers</h2> <br>
            @if (tracksLoading)
            {
                <p>Loading...</p>
            }
            else if (mnrTracks == null || mnrTracks.Tracks.Count == 0)
            {
                    <div class="controls-row">
                        <div class="button-group">
                            <button @onclick='async () => { CreationType = "TRACK"; await ReLoadMNRS(); }' disabled="@(CreationType == "TRACK")">TRACKS</button>
                            <button @onclick='async () => {CreationType = "CHARACTER"; await ReLoadMNRS();}' disabled="@(CreationType == "CHARACTER")">MODS</button>
                            <button @onclick='async () => { CreationType = "KART"; await ReLoadMNRS(); }' disabled="@(CreationType == "KART")">KARTS</button>
                        </div>
                    </div>
                    <button @onclick='async () => { await ReLoadMNRS(); }' style="padding:5px;">Reload</button> <br/>
                <p>No MNR tracks published.</p>
            }
            else
            {
                <div class="track-list">
                                        <div class="controls-row">
                        <div class="button-group">
                            <button @onclick='async () => { CreationType = "TRACK"; await ReLoadMNRS(); }' disabled="@(CreationType == "TRACK")">TRACKS</button>
                            <button @onclick='async () => {CreationType = "CHARACTER"; await ReLoadMNRS();}' disabled="@(CreationType == "CHARACTER")">MODS</button>
                            <button @onclick='async () => { CreationType = "KART"; await ReLoadMNRS(); }' disabled="@(CreationType == "KART")">KARTS</button>
                        </div>
                    </div>
                    <button @onclick='async () => { await ReLoadMNRS(); }' style="padding:5px;">Reload</button> <br>
                    @foreach (var track in mnrTracks.Tracks)
                    {
                        <div class="track-card">
                            <div class="track-preview">
                                <a href="/tracks/@track.Id">
                                    <img src="@($"{PLGarage.BaseUrl}/player_creations/{track.Id}/preview_image.png")" alt="@track.Name"
                                         onerror="this.parentElement.innerHTML=''" />
                                </a>
                            </div>
                            <div class="track-info">
                                <div class="track-name"><a href="/tracks/@track.Id">@track.Name</a></div>
                                @if (!string.IsNullOrWhiteSpace(track.Description))
                                {
                                    <div class="track-description">@track.Description</div>
                                }
                                <div class="track-stats">♥ @track.Hearts | ⬇ @track.Downloads | 🏁 @track.RacesStarted | 👁 @track.Views
                                </div>
                                <div class="tag-container">
                                    @if (track.IsTeamPick)
                                    {
                                        <span class="tag-badge tag-teampick">⭐ Team Pick</span>
                                    }
                                    @foreach (var tag in track.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries |
                                                                                                                                                StringSplitOptions.TrimEntries))
                                    {
                                        <span class="tag-badge">@tag</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            break;
        case "CMRT":
            <h2>@(CreationType)S – ModNation Racers: RoadTrip</h2> <br>
            @if (tracksLoading)
            {
                <p>Loading...</p>
            }
            else if (mnrTracks == null || mnrTracks.Tracks.Count == 0)
            {
                    <div class="controls-row">
                        <div class="button-group">
                            <button @onclick='async () => { CreationType = "TRACK"; await ReLoadMNRS(); }' disabled="@(CreationType == "TRACK")">TRACKS</button>
                            <button @onclick='async () => {CreationType = "CHARACTER"; await ReLoadMNRS();}' disabled="@(CreationType == "CHARACTER")">MODS</button>
                            <button @onclick='async () => { CreationType = "KART"; await ReLoadMNRS(); }' disabled="@(CreationType == "KART")">KARTS</button>
                        </div>
                    </div>
                    <button @onclick='async () => { await ReLoadMNRS(); }' style="padding:5px;">Reload</button> <br/>
                <p>No MNR:RT tracks published.</p>
            }
            else
            {
                <div class="track-list">
                                        <div class="controls-row">
                        <div class="button-group">
                            <button @onclick='async () => { CreationType = "TRACK"; await ReLoadMNRS(); }' disabled="@(CreationType == "TRACK")">TRACKS</button>
                            <button @onclick='async () => {CreationType = "CHARACTER"; await ReLoadMNRS();}' disabled="@(CreationType == "CHARACTER")">MODS</button>
                            <button @onclick='async () => { CreationType = "KART"; await ReLoadMNRS(); }' disabled="@(CreationType == "KART")">KARTS</button>
                        </div>
                    </div>
                    <button @onclick='async () => { await ReLoadMNRS(); }' style="padding:5px;">Reload</button> <br>
                    @foreach (var track in mnrTracks.Tracks)
                    {
                        <div class="track-card">
                            <div class="track-preview">
                                <a href="/tracks/@track.Id">
                                    <img src="@($"{PLGarage.BaseUrl}/player_creations/{track.Id}/preview_image.png")" alt="@track.Name"
                                         onerror="this.parentElement.innerHTML=''" />
                                </a>
                            </div>
                            <div class="track-info">
                                <div class="track-name"><a href="/tracks/@track.Id">@track.Name</a></div>
                                @if (!string.IsNullOrWhiteSpace(track.Description))
                                {
                                    <div class="track-description">@track.Description</div>
                                }
                                <div class="track-stats">♥ @track.Hearts | ⬇ @track.Downloads | 🏁 @track.RacesStarted | 👁 @track.Views
                                </div>
                                <div class="tag-container">
                                    @if (track.IsTeamPick)
                                    {
                                        <span class="tag-badge tag-teampick">⭐ Team Pick</span>
                                    }
                                    @foreach (var tag in track.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries |
                                                                                                                                                StringSplitOptions.TrimEntries))
                                    {
                                        <span class="tag-badge">@tag</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            break;
        case "Stats":

            <h2>Creations</h2>
            <div class="stat-row">
                <span class="stat-label">LBPK Tracks Published</span>
                <span class="stat-value">@profile.TotalTracks</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">MNR Tracks Published</span>
                <span class="stat-value">@mnrTrackCount</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">MNR Mods Published</span>
                <span class="stat-value">@mnrModCount</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">MNR Karts Published</span>
                <span class="stat-value">@mnrKartCount</span>
            </div>

            <h2>LBP Karting</h2>
            <div class="stat-row">
                <span class="stat-label">Hearts</span>
                <span class="stat-value">@profile.Hearts</span>
            </div>

            <h2>ModNation Stats</h2>
            <div class="stat-row">
                <span class="stat-label">Points</span>
                <span class="stat-value">@profile.Points</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Experience Points</span>
                <span class="stat-value">@profile.ExperiencePoints</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Creator Points</span>
                <span class="stat-value">@profile.CreatorPoints</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Rating</span>
                <span class="stat-value">@profile.Rating</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Longest Drift</span>
                <span class="stat-value">@profile.LongestDrift</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Longest Hang Time</span>
                <span class="stat-value">@profile.LongestHangTime</span>
            </div>

            <h2>Racing Performance (MNR)</h2>
            <div class="stat-row">
                <span class="stat-label">Online Races</span>
                <span class="stat-value">@profile.OnlineRaces</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Wins</span>
                <span class="stat-value">@profile.OnlineWins</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Finished</span>
                <span class="stat-value">@profile.OnlineFinished</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Forfeit</span>
                <span class="stat-value">@profile.OnlineForfeit</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Disconnected</span>
                <span class="stat-value">@profile.OnlineDisconnected</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Win Streak</span>
                <span class="stat-value">@profile.WinStreak</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Longest Win Streak</span>
                <span class="stat-value">@profile.LongestWinStreak</span>
            </div>
            break;
    }
}





@code {
    [Parameter] public int Id { get; set; }
    private string Plt = "PS3";
    private string Username = "null";
    private string activeTab = "Comments";
    private string CreationType = "TRACK";
    private PlayerProfile? profile;
    private CreationsPage? lbpkTracks;
    private CreationsPage? mnrTracks;
    private string instanceName = "PL Garage";
    private bool loading = true;
    private bool tracksLoading = true;
    private int mnrTrackCount;
    private int mnrModCount;
    private int mnrKartCount;
    private CommentsPage? comments;
    private bool commentsLoading = true;
    private int commentsPage = 1;
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private async Task ReloadLBPK(){
        if (profile != null)
        {
            var lbpkTask = PLGarage.GetTracksByPlayerIdAsync(Id, isMnr: false, username: profile.Username);
            await lbpkTask;
            lbpkTracks = lbpkTask.Result;
        }
    }
    private async Task ReLoadMNRS()
    {
        if (profile != null)
        {
            var mnrTask = PLGarage.GetTracksByPlayerIdAsync(Id, isMnr: true, platform: Plt ,username: profile.Username, type: CreationType);
            mnrTracks = await PLGarage.GetTracksByPlayerIdAsync(Id, isMnr: true, platform: Plt ,username: Username, type: CreationType);
        }
    }
    protected override async Task OnInitializedAsync()
    {
        var nameTask = PLGarage.GetInstanceNameAsync();
        var profileTask = PLGarage.GetPlayerInfoAsync(Id);
        await Task.WhenAll(nameTask, profileTask);
        await LoadComments();
        instanceName = nameTask.Result;
        profile = profileTask.Result;
        
        loading = false;

        if (profile != null)
        {
            var mnrTrackCountTask = PLGarage.GetCreationCountAsync(Id, "TRACK");
            var mnrModPS3Task = PLGarage.GetCreationCountAsync(Id, "CHARACTER", "PS3");
            var mnrModPSVTask = PLGarage.GetCreationCountAsync(Id, "CHARACTER", "PSV");
            var mnrKartPS3Task = PLGarage.GetCreationCountAsync(Id, "KART", "PS3");
            var mnrKartPSVTask = PLGarage.GetCreationCountAsync(Id, "KART", "PSV");
            var lbpkTask = PLGarage.GetTracksByPlayerIdAsync(Id, isMnr: false, username: profile.Username);
            var mnrTask = PLGarage.GetTracksByPlayerIdAsync(Id, isMnr: true, platform: Plt ,username: profile.Username, type: CreationType);
            Username = profile.Username;
            await Task.WhenAll(mnrTrackCountTask, mnrModPS3Task, mnrModPSVTask,
                               mnrKartPS3Task, mnrKartPSVTask, lbpkTask, mnrTask);

            mnrTrackCount = mnrTrackCountTask.Result;
            mnrModCount = mnrModPS3Task.Result + mnrModPSVTask.Result;
            mnrKartCount = mnrKartPS3Task.Result + mnrKartPSVTask.Result;
            lbpkTracks = lbpkTask.Result;
            mnrTracks = mnrTask.Result;
        }
        tracksLoading = false;
        
    }

    private async Task CommentsPrevPage()
    {
        if (commentsPage > 1) { commentsPage--; await LoadComments(); }
    }

    private async Task CommentsNextPage()
    {
        if (comments is not null && commentsPage < comments.TotalPages) { commentsPage++; await LoadComments(); }
    }
    private async Task LoadComments()
    {
        commentsLoading = true;
        comments = await PLGarage.GetProfileCommentsAsync(Id, commentsPage);
        commentsLoading = false;
    }

    private static string FormatDate(string dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return "-";
        try
        {
            var dt = DateTime.Parse(dateStr);
            return dt.ToString("MMM d, yyyy");
        }
        catch { return dateStr; }
    }

    private static string FormatTime(float seconds)
    {
        if (seconds <= 0) return "-";
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}.{ts.Milliseconds:D3}";
    }
}