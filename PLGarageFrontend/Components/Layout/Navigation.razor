@rendermode InteractiveServer
@using PLGarageFrontend.Services
@using PLGarageFrontend.Models
@inject PLGarageService PLGarage

<nav class="navbar">
    <div class="navbar-container">
        <a class="navbar-brand" href="/">
            <span class="navbar-icon"></span>
            @instanceName
        </a>
        <div class="navbar-links">
            <a href="/">Home</a>
            <a href="/tracks">Tracks</a>
            <a href="/mods">Mods</a>
            <a href="/karts">Karts</a>
            <a href="/photos">Photos</a>
        </div>
    </div>
</nav>

@if (announcements != null && announcements.Count > 0)
{
    <div class="announcement-banner">
        <marquee behavior="scroll" direction="left" scrollamount="4">
            @foreach (var a in announcements)
            {
                <span class="announcement-item">
                    <strong>@a.Subject</strong>
                    @if (!string.IsNullOrWhiteSpace(a.Text))
                    {
                        <span> - @a.Text</span>
                    }
                </span>
                <span class="announcement-separator">|</span>
            }
        </marquee>
    </div>
}

@code {
    private string instanceName = "PL Garage";
    private List<AnnouncementEntry>? announcements;

    protected override async Task OnInitializedAsync()
    {
        var nameTask = PLGarage.GetInstanceNameAsync();
        var announcementsTask = PLGarage.GetAnnouncementsAsync();
        await Task.WhenAll(nameTask, announcementsTask);
        instanceName = nameTask.Result;
        announcements = announcementsTask.Result;
    }
}